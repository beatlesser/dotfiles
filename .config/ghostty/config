command = /usr/bin/fish
font-size = 14
font-family = "JetBrainsMono Nerd Font"
font-family = "Symbols Nerd Font"
font-style = Regular
font-feature = +cv12
font-feature = +cv18
font-codepoint-map = U+e000-U+e00a,U+ea60-U+ebeb,U+e0a0-U+e0c8,U+e0ca,U+e0cc-U+e0d7,U+e200-U+e2a9,U+e300-U+e3e3,U+e5fa-U+e6b1,U+e700-U+e7c5,U+ed00-U+efc1,U+f000-U+f2ff,U+f000-U+f2e0,U+f300-U+f372,U+f400-U+f533,U+f0001-U+f1af0=Symbols Nerd Font Mono
confirm-close-surface = false
cursor-style=block
term = xterm-256color
mouse-hide-while-typing = true
window-decoration = false
shell-integration-features = no-cursor
window-padding-y = 10
window-padding-x = 10
window-padding-balance = true
window-vsync = true
gtk-single-instance = true
theme = noctalia

keybind = ctrl+digit_1=text:\x02\x31
keybind = ctrl+digit_2=text:\x02\x32
keybind = ctrl+digit_3=text:\x02\x33
keybind = ctrl+digit_4=text:\x02\x34
keybind = ctrl+digit_5=text:\x02\x35
keybind = ctrl+digit_6=text:\x02\x36
keybind = ctrl+digit_7=text:\x02\x37
keybind = ctrl+digit_8=text:\x02\x38
keybind = ctrl+digit_9=text:\x02\x39

# New tmux window on Cmd+t in tmux it is Ctrl+b+c
keybind = ctrl+t=text:\x02\x63

# Close tmux pane on Cmd+w in tmux it is Ctrl+b+x (it is using a custom keybind in tmux to kill the pane)
keybind = ctrl+w=text:\x02\x78

# Switch to a window using tmux-fzf on Cmd+p in tmux it is Ctrl+b+w
keybind = ctrl+shift+o=text:\x02\x77

# Rename a tmux window on Cmd+r in tmux it is Ctrl+b+,
keybind = ctrl+r=text:\x02\x2c

# Go to the previous tmux window on Cmd+h in tmux it is Ctrl+b+p
keybind = ctrl+]=text:\x02\x70

# Go to te next tmux window on Cmd+l in tmux it is Ctrl+b+n
keybind = ctrl+[=text:\x02\x6e

# Split the window horizontally on Cmd+minus in tmux it is Ctrl+b+" (For me it is horizontal split but in tmux it is considered vertical split)
keybind = ctrl+-=text:\x02\x22

# Split the window vertically on Cmd+backslash in tmux it is Ctrl+b+% (For me it is vertical split but in tmux it is considered horizontal split)
keybind = ctrl+backslash=text:\x02\x25

# Toggle pane zoom on Cmd+z in tmux it is Ctrl+b+z
keybind = ctrl+shift+n=text:\x02\x7a

