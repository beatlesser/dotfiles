input {
    mod-key "Alt"
    mod-key-nested "Super"
    keyboard {
        xkb {

        }
    }
    touchpad {
        natural-scroll
    }
    mouse {

    }
    trackpoint {

    }
}

output "HDMI-A-1" {
    mode "1920x1080@180.000"
    scale 1.0
}
output "eDP-1" {
    // Uncomment this line to disable this output.
    //off
}
